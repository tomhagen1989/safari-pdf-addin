{
  "manifest_version": 2,
  "name": "PDF Saver",
  "short_name": "PDF Saver",
  "version": "1.0.0",
  "description": "Convert any article to a clean, readable PDF — a reliable alternative to Safari Reader Mode.",
  "permissions": ["activeTab", "storage"],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "32":  "icons/icon-32.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
